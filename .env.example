# Vercel Postgres connection string. Automatski se postavlja kad se u
# Vercel projektu doda Postgres store (Storage tab); za lokalni razvoj:
# `vercel env pull .env.local` nakon što je store povezan s projektom.
POSTGRES_URL=postgres://user:password@host/db?sslmode=require
# Adresa poslužitelja za simulator (kada se pokreće na drugom uređaju npr. Raspberry Pi)
INGEST_URL=http://localhost:3000/api/ingest
